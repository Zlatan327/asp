# ─── Database ─────────────────────────────
DATABASE_URL="file:./dev.db"

# ─── Auth ─────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-this-to-a-random-secret-in-production"

# ─── LLM Provider ────────────────────────
LLM_PROVIDER="google"
GOOGLE_API_KEY="your-gemini-api-key"
GOOGLE_MODEL="gemini-1.5-pro"
GOOGLE_BASE_URL="https://generativelanguage.googleapis.com/v1beta/openai"

# Option 1: OpenAI
OPENAI_API_KEY=""
OPENAI_BASE_URL="https://api.openai.com/v1"
OPENAI_MODEL="gpt-4o"

# Option 2: Google Gemini
GOOGLE_API_KEY=""
GOOGLE_BASE_URL="https://generativelanguage.googleapis.com/v1beta/openai"
GOOGLE_MODEL="gemini-1.5-pro"

# Active LLM provider: "openai" or "google"
LLM_PROVIDER="google"

# ─── Social OAuth ────────────────────────
# Keep social login off until the production OAuth callback URLs are configured.
# Wallet login remains available either way.
ENABLE_SOCIAL_LOGIN="false"

