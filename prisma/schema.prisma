// Prisma Schema for the ASP Freelancer & Indie Creator platform
// Database: PostgreSQL (or SQLite for dev)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── User & Auth ─────────────────────────────────────────

model User {
  id              String   @id @default(cuid())
  walletAddress   String?  @unique
  email           String?  @unique
  name            String?
  avatarUrl       String?
  role            String   @default("BOTH") // FREELANCER, CLIENT, BOTH
  tier            String   @default("FREE") // FREE, PRO, ENTERPRISE
  onboardedAt     DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  freelancerProfile FreelancerProfile?
  clientProfile     ClientProfile?
  socialAccounts    SocialAccount[]
  proposals         Proposal[]
  gigsPosted        Gig[]             @relation("ClientGigs")
  gigsWorked        Gig[]             @relation("FreelancerGigs")
  reputationScore   Reputation?
  agentLogs         AgentLog[]
  sentReviews       Review[]          @relation("ReviewAuthor")
  receivedReviews   Review[]          @relation("ReviewSubject")
  bountiesPosted    Bounty[]
  bountyClaims      BountyClaim[]
}

// ─── Freelancer Profile ──────────────────────────────────

model FreelancerProfile {
  id                String   @id @default(cuid())
  userId            String   @unique
  headline          String?
  bio               String?
  skills            String   @default("[]") // JSON array of skills
  experiences       String   @default("[]") // JSON array of experiences
  education         String   @default("[]") // JSON array
  cvFileUrl         String?
  credibilityScore  Float    @default(0)
  badges            String   @default("[]") // JSON array of badge IDs
  scoutReport       String?  // JSON scout analysis
  skillEmbedding    String?  // JSON vector for matching
  hourlyRate        Float?
  availability      String   @default("AVAILABLE") // AVAILABLE, BUSY, UNAVAILABLE
  completedGigs     Int      @default(0)
  totalEarned       Float    @default(0)
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Client Profile ──────────────────────────────────────

model ClientProfile {
  id             String   @id @default(cuid())
  userId         String   @unique
  companyName    String?
  industry       String?
  description    String?
  website        String?
  totalSpent     Float    @default(0)
  gigsPosted     Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Social Accounts ─────────────────────────────────────

model SocialAccount {
  id           String   @id @default(cuid())
  userId       String
  platform     String   // GITHUB, TWITTER, DISCORD
  handle       String
  profileUrl   String?
  accessToken  String?
  refreshToken String?
  verified     Boolean  @default(false)
  scanData     String?  // JSON: latest scan results
  lastScanned  DateTime?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, platform])
}

// ─── Skills Taxonomy ─────────────────────────────────────

model Skill {
  id          String @id @default(cuid())
  name        String @unique
  category    String // PROGRAMMING, DESIGN, BLOCKCHAIN, MARKETING, etc.
  demandScore Float  @default(0)
  aliases     String @default("[]") // JSON array of alternative names
}

// ─── Gigs / Tasks ────────────────────────────────────────

model Gig {
  id                   String   @id @default(cuid())
  clientId             String
  freelancerId         String?
  title                String
  description          String
  skills               String   @default("[]") // JSON array of skill names
  budget               Float
  budgetType           String   @default("FIXED") // FIXED, HOURLY
  currency             String   @default("USDT")
  status               String   @default("OPEN") // OPEN, IN_PROGRESS, COMPLETED, CANCELLED, DISPUTED
  deadline             DateTime?
  milestones           String   @default("[]") // JSON array of milestones
  escrowContractAddress String?
  escrowFunded         Boolean  @default(false)
  category             String?
  experienceLevel      String   @default("ANY") // BEGINNER, INTERMEDIATE, EXPERT, ANY
  estimatedDuration    String?
  matchScore           Float?   // AI match score for recommendations
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  client     User       @relation("ClientGigs", fields: [clientId], references: [id])
  freelancer User?      @relation("FreelancerGigs", fields: [freelancerId], references: [id])
  proposals  Proposal[]
  tasks      Task[]
  escrow     Escrow?
  reviews    Review[]
}

// ─── Proposals ───────────────────────────────────────────

model Proposal {
  id              String   @id @default(cuid())
  gigId           String
  freelancerId    String
  coverLetter     String
  bidAmount       Float
  estimatedDays   Int?
  generatedByAgent Boolean @default(false)
  agentConfidence Float?
  matchScore      Float?
  status          String   @default("PENDING") // PENDING, ACCEPTED, REJECTED, WITHDRAWN
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  gig        Gig  @relation(fields: [gigId], references: [id], onDelete: Cascade)
  freelancer User @relation(fields: [freelancerId], references: [id])

  @@unique([gigId, freelancerId])
}

// ─── Task Management ─────────────────────────────────────

model Task {
  id             String   @id @default(cuid())
  gigId          String
  title          String
  description    String?
  status         String   @default("TODO") // TODO, IN_PROGRESS, REVIEW, DONE
  milestoneIndex Int?
  deliverables   String   @default("[]") // JSON array of deliverable URLs
  dueDate        DateTime?
  order          Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  gig Gig @relation(fields: [gigId], references: [id], onDelete: Cascade)
}

// ─── Escrow ──────────────────────────────────────────────

model Escrow {
  id               String   @id @default(cuid())
  gigId            String   @unique
  contractAddress  String?
  chainId          Int      @default(196) // X Layer mainnet
  tokenAddress     String?  // USDT contract address
  totalAmount      Float
  releasedAmount   Float    @default(0)
  status           String   @default("PENDING") // PENDING, FUNDED, PARTIALLY_RELEASED, COMPLETED, DISPUTED, REFUNDED
  milestoneDetails String   @default("[]") // JSON: per-milestone escrow status
  txHash           String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  gig Gig @relation(fields: [gigId], references: [id], onDelete: Cascade)
}

// ─── Reputation ──────────────────────────────────────────

model Reputation {
  id                String   @id @default(cuid())
  userId            String   @unique
  overallScore      Float    @default(50) // 0-100
  profileScore      Float    @default(0)
  socialScore       Float    @default(0)
  completionScore   Float    @default(0)
  ratingScore       Float    @default(0)
  deliveryScore     Float    @default(0)
  disputeScore      Float    @default(0)
  socialReliabilityScore Float @default(50) // For Micro-Bounties
  tasksCompleted    Int      @default(0)    // For unlocking Auto-Bounty Bot
  badges            String   @default("[]") // JSON array of badge objects
  onChainTokenId    String?
  onChainSynced     Boolean  @default(false)
  lastSyncedAt      DateTime?
  history           String   @default("[]") // JSON array of score snapshots
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Reviews ─────────────────────────────────────────────

model Review {
  id        String   @id @default(cuid())
  gigId     String
  authorId  String
  subjectId String
  rating    Float    // 1-5
  comment   String?
  createdAt DateTime @default(now())

  gig     Gig  @relation(fields: [gigId], references: [id], onDelete: Cascade)
  author  User @relation("ReviewAuthor", fields: [authorId], references: [id])
  subject User @relation("ReviewSubject", fields: [subjectId], references: [id])

  @@unique([gigId, authorId])
}

// ─── Agent Logs ──────────────────────────────────────────

model AgentLog {
  id        String   @id @default(cuid())
  userId    String?
  agentType String   // SCOUT, MATCHER, PROPOSAL, TASK_MANAGER, REPUTATION, ORCHESTRATOR
  action    String
  input     String?  // JSON
  output    String?  // JSON
  status    String   @default("SUCCESS") // SUCCESS, ERROR, PENDING
  duration  Int?     // milliseconds
  cost      Float?   // LLM API cost
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])
}

// ─── Micro-Bounties (Social) ─────────────────────────────

model Bounty {
  id             String   @id @default(cuid())
  clientId       String
  title          String
  description    String
  platform       String   // TWITTER, DISCORD, etc.
  action         String   // LIKE, RETWEET, FOLLOW
  targetUrl      String
  targetAccount  String?
  poolAmount     Float    // Total USDT locked in contract
  rewardAmount   Float    // Reward per user
  maxParticipants Int     @default(100)
  participantsCount Int   @default(0)
  status         String   @default("OPEN") // OPEN, COMPLETED, CANCELLED
  contractAddress String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  client         User          @relation(fields: [clientId], references: [id])
  claims         BountyClaim[]
}

model BountyClaim {
  id           String   @id @default(cuid())
  bountyId     String
  userId       String
  status       String   @default("PENDING") // PENDING, VERIFIED, REJECTED
  proofData    String?  // JSON: ZK proof or mocked receipt
  txHash       String?  // Tx hash of the payout
  autoClaimed  Boolean  @default(false) // Was this claimed by the Auto-Bounty Bot?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  bounty Bounty @relation(fields: [bountyId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([bountyId, userId])
}
